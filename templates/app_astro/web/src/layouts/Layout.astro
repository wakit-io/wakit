---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'App Astro' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
  <!-- shared content styles (single source for web + app) -->
  <link rel="stylesheet" href="/app-shared.css" />
  <!-- PWA: installable from the web too (launches the app at start_url) -->
  <link rel="manifest" href="/app/manifest.json" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
  <!-- theme: same script the app uses (key 'blog-theme', sets [data-theme]); prevents FOUC -->
  <script is:inline src="/app/js/theme-init.js"></script>
</head>
<body>
  <!-- Web chrome: data-spa-ignore → stripped when the wakit app fetches this page -->
  <nav class="nav" data-spa-ignore>
    <div class="nav__inner">
      <a href="/" class="nav__logo">App Astro</a>
      <div class="nav__links">
        <a href="/">Home</a>
        <a href="/board/">Board</a>
        <a href="/profile/">Profile</a>
      </div>
      <button type="button" class="nav__theme" data-theme-toggle aria-label="Toggle theme"><i class="bi bi-moon-fill"></i></button>
      <a href="/app/app.html" class="nav__cta">Open app</a>
    </div>
  </nav>

  <slot />

  <footer class="foot" data-spa-ignore>
    <div class="foot__inner">
      <span>WAKIT · web (Astro) + app (wakit.js)</span>
    </div>
  </footer>

  <!-- theme toggle delegation — same script as the app. data-spa-ignore so the app
       (which has its own copy) strips it when it fetches this page. -->
  <script is:inline src="/app/js/theme-toggle.js" data-spa-ignore></script>
  <!-- PWA service worker (root scope → offline). Skipped on localhost to avoid dev caching. -->
  <script is:inline data-spa-ignore>
    if ('serviceWorker' in navigator && !['localhost', '127.0.0.1'].includes(location.hostname)) {
      window.addEventListener('load', function () { navigator.serviceWorker.register('/service-worker.js'); });
    }
  </script>
</body>
</html>
