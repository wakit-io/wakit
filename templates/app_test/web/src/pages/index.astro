---
import Layout from '../layouts/Layout.astro';
---
<Layout title="App Test - 홈">
  <main>
    <section style="text-align:center; padding: 100px 24px 60px;">
      <h1 style="font-size:2.5rem; font-weight:800; margin-bottom:16px;">
        App Test
      </h1>
      <p style="font-size:1.125rem; color:var(--text-secondary); margin-bottom:36px;">
        모바일 앱처럼 동작하는 웹 서비스
      </p>
      <a href="/app/app.html" style="
        display:inline-block; padding:14px 36px;
        background:var(--primary); color:#fff;
        border-radius:12px; font-size:1rem; font-weight:700;
      ">앱 시작하기</a>
    </section>
  </main>
</Layout>
