{
  "splashDelay": 100,
  "splashForce": false,
  "tabbar": { "autoHide": false, "hideThreshold": 14, "displayMode": "web" },
  "pullToRefresh": {
    "threshold": 90,
    "startSlop": 18,
    "damping": 0.35,
    "maxPull": 200,
    "disablePages": ["home"]
  },
  "appbarView": false,
  "theme": {
    "primaryColor": "#6366f1",
    "font": "Pretendard, system-ui",
    "isMobile": true
  },
  "defaultTab": "home",
  "tabs": [
    { "id": "home",    "label": "홈",   "icon": "fi fi-rr-home",   "page": "home" },
    { "id": "explore", "label": "탐색", "icon": "fi fi-rr-search", "page": "explore" },
    { "id": "notify",  "label": "알림", "icon": "fi fi-rr-bell",   "page": "notify" },
    { "id": "profile", "label": "프로필","icon": "fi fi-rr-user",  "page": "profile" }
  ],
  "routes": [
    { "path": "home",    "file": "../views/home.html",          "title": "홈" },
    { "path": "explore", "file": "../views/explore.html",       "title": "탐색" },
    { "path": "notify",  "file": "../views/notifications.html", "title": "알림" },
    { "path": "profile", "file": "../views/profile.html",       "title": "프로필" },
    { "path": "detail",  "file": "../views/detail.html",        "title": "상세" },
    { "path": "signup",  "file": "../views/signup.html",        "title": "회원가입" },
    { "path": "login",   "file": "../views/login.html",         "title": "로그인" }
  ]
}
