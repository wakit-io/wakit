# dependencies
node_modules/
templates/*/web/node_modules/

# build outputs
dist/
templates/*/dist/

# Astro build cache
templates/*/web/.astro/

# === Templates: version ONLY the canonical app_basic / app_astro / app_sveltekit ===
# Any other template under templates/ (test/scratch templates) is ignored,
# so it won't be committed or pushed to GitHub.
templates/*
!templates/app_basic/
!templates/app_astro/
!templates/app_sveltekit/
# ...but still ignore build artifacts inside the canonical templates
templates/*/web/node_modules/
templates/*/dist/
templates/*/web/.astro/
# SvelteKit build cache + webpack-generated static assets (web layer output)
templates/*/web/.svelte-kit/
templates/*/web/public/app/
templates/*/web/public/wakit/
templates/*/web/public/service-worker.js

# SQL (Supabase 마이그레이션 — 로컬/생성물, 커밋 제외)
*.sql

# Supabase 로컬 config — 템플릿마다 api.schemas 등이 누적되므로 커밋 제외
supabase/config.toml

# Supabase 이메일 템플릿(app_bookpress 로컬 설정 — config.toml 이 참조) 커밋 제외
supabase/templates/

# Auth provider env (구글 OAuth 등) — 실제 키 파일 + 로컬 전용 예시까지 커밋 제외
supabase/google-oauth.env
supabase/google-oauth.env.example
*.env.local

# 기획/플랜 문서 (로컬 작업용, 커밋 제외)
/APP_PLAN.md

# OS/editor noise (optional but helpful)
.DS_Store
Thumbs.db
.vscode/
*.log

# Local Netlify folder
.netlify
