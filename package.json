{
  "name": "wakit-js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:app_test": "webpack serve --mode development --env template=app_test",
    "dev:app_basic": "webpack serve --mode development --env template=app_basic",
    "build:app_test": "node scripts/build-template.js app_test",
    "build:app_basic": "node scripts/build-template.js app_basic",
    "web:dev": "cd templates/app_test/web && npm run dev",
    "preview": "npx serve dist -l 5173",
    "package": "node scripts/package-template.js",
    "package:app_test": "TEMPLATE=app_test node scripts/package-template.js",
    "package:app_basic": "TEMPLATE=app_basic node scripts/package-template.js",
    "create:custom": "node scripts/create-customization-project.js",
    "create:cms": "node scripts/create-cms-project.js",
    "create:template": "node scripts/create-template.js",
    "scaffold:template": "node scripts/scaffold-template.js",
    "delete:template": "node scripts/delete-template.js"
  },
  "devDependencies": {
    "cheerio": "^1.1.0",
    "copy-webpack-plugin": "^12.0.2",
    "javascript-obfuscator": "^5.4.2",
    "terser": "^5.31.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
