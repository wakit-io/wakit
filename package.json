{
  "name": "hybrid-ui-framework",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:app_test": "webpack serve --mode development --env template=app_test",
    "dev:app_hotel": "webpack serve --mode development --env template=app_hotel",
    "dev:app_basic": "webpack serve --mode development --env template=app_basic",
    "dev:app_theme": "webpack serve --mode development --env template=app_theme",
    "build:app_test": "webpack --mode production --env template=app_test && cd templates/app_test/web && npm run build",
    "build:app_hotel": "webpack --mode production --env template=app_hotel && cd templates/app_hotel/web && npm run build",
    "build:app_basic": "webpack --mode production --env template=app_basic && cd templates/app_basic/web && npm run build",
    "build:app_theme": "webpack --mode production --env template=app_theme && cd templates/app_theme/web && npm run build",
    "web:dev": "cd templates/app_test/web && npm run dev",
    "preview": "npx serve dist -l 5173",
    "package": "node scripts/package-template.js",
    "package:app_test": "TEMPLATE=app_test node scripts/package-template.js",
    "package:app_basic": "TEMPLATE=app_basic node scripts/package-template.js",
    "package:app_hotel": "TEMPLATE=app_hotel node scripts/package-template.js",
    "package:app_theme": "TEMPLATE=app_theme node scripts/package-template.js",
    "create:custom": "node scripts/create-customization-project.js",
    "create:cms": "node scripts/create-cms-project.js",
    "create:template": "node scripts/create-template.js",
    "delete:template": "node scripts/delete-template.js"
  },
  "devDependencies": {
    "cheerio": "^1.1.0",
    "copy-webpack-plugin": "^12.0.2",
    "javascript-obfuscator": "^5.4.2",
    "terser": "^5.31.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
